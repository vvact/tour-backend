[flake8]
max-line-length = 118
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    migrations,
    venv,
    env,
    node_modules

# Per‑file exceptions – keeps code clean without littering `# noqa`
per-file-ignores =
    tour_backend/settings/*.py: F401,F403,F405
    apps/*/admin.py: F401
    apps/*/models.py: F401
    apps/*/tests.py: F401
    apps/core/exceptions.py: F401